{
  "homepage": "https://axharfolio.live/",
  "name": "axharfolio-live",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^16.4.7",
    "gh-pages": "^6.2.0",
    "lottie-react": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-emoji": "^1.8.1",
    "react-headroom": "^3.2.1",
    "react-twitter-embed": "^4.0.4",
    "sass": "^1.83.0"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "vite": "^6.0.7"
  },
  "scripts": {
    "predeploy": "npm run build",
    "start": "vite --host 0.0.0.0 --port 3000",
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "node fetch.js && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "deploy": "gh-pages -b master -d dist",
    "format": "prettier --write \"./**/*.{js,jsx,css,json,scss,html}\"",
    "check-format": "prettier -c \"./**/*.{js,jsx,css,json,scss,html}\""
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  }
}
